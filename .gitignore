# ============================================================
# Burp Upstream HTTPS Proxy Adapter - .gitignore
# ============================================================

# ------ Go ------
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Coverage profiles and test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# go-task build cache (machine-local mtime checksums; never commit)
.task/

# Go workspace
go.work
go.work.sum

# Dependency vendoring (uncomment if vendoring)
# vendor/

# ------ Wails / Frontend ------
# Node dependencies
frontend/node_modules/

# Vite build output (rebuilt by `wails build` / `npm run build`)
frontend/dist/

# Wails v2 checksum file (no longer generated by v3, kept for safety)
frontend/package.json.md5

# Legacy npm lockfile (we use bun → frontend/bun.lock is committed instead)
frontend/package-lock.json

# Wails build output (v2 used build/bin, v3 outputs to bin/)
build/bin/
bin/

# Wails v3 generated TS bindings (regenerated via `wails3 generate bindings`)
frontend/bindings/

# Vitest / V8 coverage output (HTML reports + lcov, regenerated by `bun run test:coverage`)
frontend/coverage/

# TypeScript incremental compile cache
*.tsbuildinfo

# ------ App config (runtime-generated, may contain user data) ------
*.config.json

# ------ Secrets / credentials (NEVER commit these) ------
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore

# ------ OS-generated junk ------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.lnk

# ------ Editor / IDE ------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
