# ============================================================
# Burp Upstream HTTPS Proxy Adapter - .gitignore
# ============================================================

# ------ Go ------
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Coverage profiles and test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace
go.work
go.work.sum

# Dependency vendoring (uncomment if vendoring)
# vendor/

# ------ Wails / Frontend ------
# Node dependencies
frontend/node_modules/

# Vite build output (rebuilt by `wails build` / `npm run build`)
frontend/dist/

# Wails checksum file (auto-generated, machine-specific)
frontend/package.json.md5

# Wails build output
build/bin/

# ------ App config (runtime-generated, may contain user data) ------
*.config.json

# ------ Secrets / credentials (NEVER commit these) ------
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore

# ------ OS-generated junk ------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.lnk

# ------ Editor / IDE ------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
